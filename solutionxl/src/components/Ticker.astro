---
const items = [
  'IT-infrastructuur',
  'Programma & regie',
  'Interim management',
  'Product Ownership',
  'Multidisciplinaire teams',
  'Multi-vendor governance',
  'On/offshore aansturing',
  'Senior interim',
];
// Dubbel om seamless scroll te creëren
const track = [...items, ...items];
---

<div class="ticker-top" aria-hidden="true">
  <div class="ticker-track">
    {track.map((t) => <span>{t}</span>)}
  </div>
</div>

<style>
  .ticker-top {
    background: var(--ink);
    color: var(--bg);
    border-bottom: 1px solid var(--ink);
    overflow: hidden;
    padding-block: 0.55rem;
  }

  .ticker-track {
    display: flex;
    gap: 3rem;
    animation: scroll 60s linear infinite;
    width: max-content;
  }

  .ticker-track span {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--bg);
    white-space: nowrap;
  }

  .ticker-track span::before {
    content: '◆  ';
    color: var(--accent);
  }

  @keyframes scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
</style>
