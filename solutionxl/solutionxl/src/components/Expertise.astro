---
const expertises = [
  {
    num: '01',
    title: 'Programma-regie',
    body: 'Regie op programma\'s waar meerdere teams, leveranciers en stakeholders samenkomen. Inrichten van governance, besluitvorming en escalatielijnen — zodat het programma stuurbaar blijft, ook onder druk.',
    keywords: ['Governance', 'Stuurgroep', 'Multi-vendor'],
    href: '/programma-regie/',
  },
  {
    num: '02',
    title: 'Product Ownership van multidisciplinaire teams',
    body: 'Aansturen van multidisciplinaire teams, on- en offshore. Roadmap en backlog vertalen naar releases die tellen, stakeholders managen, en zorgen dat ontwikkelaars, testers, analisten en architecten als één team leveren.',
    keywords: ['Product Owner', 'On/offshore', 'Multidisciplinair'],
    href: '/product-ownership/',
  },
  {
    num: '03',
    title: 'Release management in grote programma\'s',
    body: 'Releases tussen meerdere partijen — overheid, system integrator, on/offshore — afgestemd in één roadmap. Stuurinformatie waarop de regiegroep maandelijks bijstuurt op tijd, budget en capaciteit.',
    keywords: ['Release roadmap', 'Multi-partij', 'Stuurinformatie'],
    href: '/release-management/',
  },
  {
    num: '04',
    title: 'Interim director-rollen in tech-organisaties',
    body: 'Tijdelijk eindverantwoordelijk voor een tech-afdeling — directeur Development & Operations, hoofd DevOps, lead van een planningcel. Met de senioriteit om vanaf dag één bestuurlijk én operationeel te sturen.',
    keywords: ['Director a.i.', 'DevOps', 'Tech-strategie'],
    href: '/interim-versterking/',
  },
];
---

<section class="expertise" id="expertise">
  <div class="wrap">
    <header class="exp-head">
      <span class="mono">§ Expertise</span>
      <h2>Vier specialisaties. <em>Eén</em> rode draad.</h2>
      <p class="exp-lede">Waar veel partijen samenkomen, breng ik rust in het programma.</p>
    </header>

    <div class="exp-grid">
      {expertises.map((e) => (
        <a class="exp-card" href={e.href}>
          <div class="exp-top">
            <span class="mono">{e.num}</span>
            <span class="exp-arrow">↗</span>
          </div>
          <h3 class="exp-title">{e.title}</h3>
          <p class="exp-body">{e.body}</p>
          <ul class="exp-tags">
            {e.keywords.map((k) => <li>{k}</li>)}
          </ul>
          <span class="exp-readmore mono">Lees meer →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .expertise { padding-block: clamp(5rem, 10vw, 9rem); }

  .exp-head {
    max-width: 36rem;
    margin-bottom: clamp(3rem, 6vw, 5rem);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .exp-head .mono { color: var(--accent); }
  .exp-head h2 {
    font-family: var(--serif);
    font-size: clamp(2.2rem, 4.5vw, 3.8rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-weight: 400;
  }
  .exp-head h2 em { color: var(--accent); }
  .exp-lede {
    font-size: 1.1rem;
    color: var(--ink-2);
    line-height: 1.55;
    max-width: 50ch;
    margin-top: 0.5rem;
  }

  .exp-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border-top: 1px solid var(--ink);
    border-left: 1px solid var(--ink);
  }

  .exp-card {
    padding: clamp(1.8rem, 3vw, 2.5rem);
    border-right: 1px solid var(--ink);
    border-bottom: 1px solid var(--ink);
    background: var(--bg);
    transition: background 0.4s ease, color 0.4s ease;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-height: 21rem;
    color: var(--ink);
    cursor: pointer;
    text-decoration: none;
  }
  .exp-card:hover { background: var(--ink); color: var(--bg); }
  .exp-card:hover .exp-body { color: color-mix(in srgb, var(--bg) 80%, transparent); }
  .exp-card:hover .mono { color: var(--accent); }
  .exp-card:hover .exp-tags li {
    border-color: color-mix(in srgb, var(--bg) 25%, transparent);
    color: var(--bg);
  }
  .exp-card:hover .exp-arrow { color: var(--accent); transform: translate(4px, -4px); }
  .exp-card:hover .exp-readmore { color: var(--accent); }

  .exp-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }
  .exp-top .mono { color: var(--muted); transition: color 0.4s ease; }
  .exp-arrow { font-size: 1.1rem; transition: transform 0.3s, color 0.3s; }

  .exp-title {
    font-family: var(--serif);
    font-size: clamp(1.4rem, 2.2vw, 1.8rem);
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1.1;
  }
  .exp-title em { font-style: italic; color: var(--accent); }

  .exp-body {
    font-size: 0.98rem;
    line-height: 1.55;
    color: var(--ink-2);
    flex: 1;
    transition: color 0.4s ease;
  }

  .exp-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    list-style: none;
    margin-top: 0.5rem;
  }
  .exp-tags li {
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    border: 1px solid var(--rule);
    color: var(--ink-2);
    transition: all 0.4s ease;
  }

  .exp-readmore {
    color: var(--accent);
    margin-top: 0.5rem;
    transition: color 0.3s;
  }

  @media (max-width: 700px) {
    .exp-grid { grid-template-columns: 1fr; }
    .exp-card { min-height: auto; }
  }
</style>
