---
const facts = [
  { num: '40+', unit: 'jr', label: 'IT-ervaring<br>sinds 1983' },
  { num: '7+', unit: '', label: 'sectoren — overheid, banking,<br>energie, luchtvaart, NGO' },
  { num: '60', unit: '', label: 'on/offshore ontwikkelaars<br>aangestuurd (Xebia)' },
  { num: '24', unit: '', label: 'mensen in 4 teams<br>geleid bij Rainforest' },
];
---

<section class="facts">
  <div class="wrap facts-grid">
    {facts.map((f) => (
      <div class="fact">
        <span class="fact-num">{f.num}{f.unit && <span class="unit">{f.unit}</span>}</span>
        <span class="fact-label" set:html={f.label} />
      </div>
    ))}
  </div>
</section>

<style>
  .facts {
    background: var(--ink);
    color: var(--bg);
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  .facts-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }

  .fact {
    padding: 1rem clamp(1rem, 2vw, 1.5rem);
    border-right: 1px solid color-mix(in srgb, var(--bg) 15%, transparent);
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  .fact:last-child { border-right: none; }

  .fact-num {
    font-family: var(--serif);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--bg);
  }
  .fact-num .unit {
    font-size: 0.4em;
    color: var(--accent);
    margin-left: 0.2em;
    font-style: italic;
  }

  .fact-label {
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--bg) 60%, transparent);
    line-height: 1.5;
  }

  @media (max-width: 800px) {
    .facts-grid { grid-template-columns: repeat(2, 1fr); }
    .fact:nth-child(2) { border-right: none; }
    .fact:nth-child(1), .fact:nth-child(2) {
      border-bottom: 1px solid color-mix(in srgb, var(--bg) 15%, transparent);
      padding-bottom: 2rem;
    }
    .fact:nth-child(3), .fact:nth-child(4) { padding-top: 2rem; }
  }
</style>
