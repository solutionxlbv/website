---
import { BLOG_ENABLED } from '../config';
---
<header class="nav">
  <div class="wrap nav-inner">
    <a href="/" class="logo" aria-label="SolutionXL home">
      <span class="logo-mark">Solution<b>XL</b></span>
      <span class="logo-tag">Henk v/d Weele · Diemen</span>
    </a>

    <!-- Desktop nav -->
    <nav class="nav-desktop" aria-label="Hoofdnavigatie">
      <ul class="nav-links">
        <li><a href="/#expertise">Expertise</a></li>
        <li><a href="/#cases">Cases</a></li>
        <li><a href="/#bewijs">Track record</a></li>
        {BLOG_ENABLED && <li><a href="/blog/">Blog</a></li>}
        <li><a href="/#contact" class="nav-cta">Bel Henk</a></li>
      </ul>
    </nav>

    <!-- Mobile nav: hamburger via details/summary -->
    <details class="nav-mobile">
      <summary aria-label="Open menu">
        <span class="hamburger">
          <span></span>
          <span></span>
          <span></span>
        </span>
      </summary>
      <div class="nav-mobile-panel">
        <ul>
          <li><a href="/#expertise">Expertise</a></li>
          <li><a href="/#cases">Cases</a></li>
          <li><a href="/#bewijs">Track record</a></li>
          <li><a href="/#over">Over</a></li>
          {BLOG_ENABLED && <li><a href="/blog/">Blog</a></li>}
          <li><a href="/#contact" class="nav-cta-mobile">Bel Henk</a></li>
        </ul>
      </div>
    </details>
  </div>
</header>

<script>
  // Mobile nav menu — gedrag voor robuust UX
  const navDetails = document.querySelector('.nav-mobile');
  const navHeader = document.querySelector('.nav');

  if (navDetails && navHeader) {
    // 1. Header-hoogte dynamisch meten en als CSS-var zetten
    const setNavHeight = () => {
      const h = navHeader.offsetHeight;
      document.documentElement.style.setProperty('--nav-height', `${h}px`);
    };
    setNavHeight();
    window.addEventListener('resize', setNavHeight);

    // 2. Menu sluiten bij klik op een link erin
    navDetails.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        navDetails.open = false;
      });
    });

    // 3. Menu sluiten bij tap/klik buiten het menu
    document.addEventListener('click', (e) => {
      if (!navDetails.open) return;
      if (!navDetails.contains(e.target)) {
        navDetails.open = false;
      }
    });

    // 4. Menu sluiten bij Escape-toets
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && navDetails.open) {
        navDetails.open = false;
      }
    });
  }
</script>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s;
  }
  .nav:hover { border-bottom-color: var(--rule); }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 1rem;
  }

  .logo { display: flex; align-items: baseline; gap: 0.75rem; }

  .logo-mark {
    font-family: var(--serif);
    font-size: 1.5rem;
    line-height: 1;
    font-style: italic;
    color: var(--ink);
  }
  .logo-mark b { font-style: normal; color: var(--accent); font-weight: 400; }

  .logo-tag {
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    padding-left: 0.75rem;
    border-left: 1px solid var(--rule);
  }

  /* DESKTOP NAV */
  .nav-desktop { display: block; }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    align-items: center;
    list-style: none;
  }

  .nav-links a {
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-2);
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--accent); }

  .nav-cta {
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    background: var(--ink);
    color: var(--bg) !important;
    padding: 0.6rem 1.1rem;
    border-radius: 999px;
    transition: background 0.25s;
  }
  .nav-cta:hover { background: var(--accent) !important; color: var(--bg) !important; }

  /* MOBILE NAV - HIDDEN OP DESKTOP */
  .nav-mobile { display: none; }

  /* HAMBURGER ICOON */
  .nav-mobile summary {
    list-style: none;
    cursor: pointer;
    padding: 0.5rem;
    margin: -0.5rem;
    -webkit-tap-highlight-color: transparent;
  }
  .nav-mobile summary::-webkit-details-marker { display: none; }
  .nav-mobile summary::marker { display: none; }

  .hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    width: 24px;
  }
  .hamburger span {
    display: block;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
    transition: transform 0.3s, opacity 0.3s;
    transform-origin: center;
  }

  /* HAMBURGER → KRUISJE wanneer menu open */
  .nav-mobile[open] .hamburger span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-mobile[open] .hamburger span:nth-child(2) {
    opacity: 0;
  }
  .nav-mobile[open] .hamburger span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* MOBIEL PANEEL */
  .nav-mobile-panel {
    position: fixed;
    top: var(--nav-height, 64px);
    left: 0;
    right: 0;
    background: var(--bg);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding: 0.5rem var(--pad);
    animation: slideDown 0.25s ease;
    box-shadow: 0 8px 24px color-mix(in srgb, var(--ink) 8%, transparent);
  }

  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .nav-mobile-panel ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .nav-mobile-panel li {
    border-bottom: 1px solid var(--rule);
  }
  .nav-mobile-panel li:last-child {
    border-bottom: none;
    padding-block: 0.75rem 0.25rem;
  }
  .nav-mobile-panel a {
    display: block;
    padding: 1rem 0;
    font-family: var(--mono);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-2);
    transition: color 0.2s, padding-left 0.2s;
  }
  .nav-mobile-panel a:hover {
    color: var(--accent);
    padding-left: 0.5rem;
  }
  .nav-cta-mobile {
    background: var(--ink);
    color: var(--bg) !important;
    padding: 0.85rem 1.1rem !important;
    border-radius: 999px;
    text-align: center;
    transition: background 0.25s;
  }
  .nav-cta-mobile:hover { background: var(--accent) !important; padding-left: 1.1rem !important; }

  @media (max-width: 800px) {
    .logo-tag { display: none; }
    .nav-desktop { display: none; }
    .nav-mobile { display: block; }
  }
</style>
